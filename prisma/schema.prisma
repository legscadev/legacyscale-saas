// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Connection URLs live in prisma.config.ts (required by Prisma 7).
  // Runtime app uses DATABASE_URL via the pg adapter in lib/prisma.ts;
  // Prisma CLI commands (migrate, db push) use DIRECT_URL configured
  // in prisma.config.ts.
}

// ============================================
// ENUMS
// ============================================

enum Role {
  ADMIN
  TEAM
  MEMBER
}

// ============================================
// MULTI-TENANCY (Phase 1 — see docs/multi-tenancy.md)
// ============================================
//
// Role a user carries inside a specific Company. Distinct from
// User.role (which is being phased out — will be dropped in Phase 7).
// Per-company scope: one user can be OWNER in Company A and MEMBER
// in Company B.
enum CompanyRole {
  OWNER // Full control of the company; can invite ADMINs, change branding, delete the company
  ADMIN // Everything except deleting the company + swapping the owner
  TEAM // Internal team member — same as today's TEAM role
  MEMBER // Student — same as today's MEMBER role
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

/// Who can see a course beyond admins.
/// - MEMBERS:  shown in the member catalog only (default).
/// - INTERNAL: shown only to internal/admin team — hidden from members.
/// - BOTH:     shown in the member catalog AND the internal section.
enum CourseAudience {
  MEMBERS
  INTERNAL
  BOTH
}

enum LessonType {
  VIDEO
  QUIZ
  RESOURCE
}

enum LessonStatus {
  DRAFT
  PROCESSING
  READY
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
}

enum AnnouncementStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
}

enum AnnouncementCategory {
  GENERAL
  OFFICE_HOURS
  COURSE_UPDATE
  IMPORTANT
}

enum AnnouncementAuditAction {
  CREATED
  UPDATED
  PUBLISHED
  UNPUBLISHED
  DELETED
  RESTORED
}

enum EnrollmentStatus {
  PENDING
  ACTIVE
  // Course finished — `completedAt` is set, the user keeps access until
  // `expiresAt`. Distinct from ACTIVE so cohort filters can split
  // "currently learning" from "already completed" without re-deriving
  // the state from progressPercent or completedAt.
  COMPLETED
  EXPIRED
  REVOKED
}

enum EnrollmentSource {
  MANUAL
  GHL_WEBHOOK
  ADMIN
  SELF_ENROLL
}

/// Employment lifecycle state for an internal Employee record.
enum EmploymentStatus {
  ACTIVE
  OFFBOARDED
}

/// Per-item state on an employee's onboarding checklist. Mirrors the
/// original spreadsheet vocabulary:
///   OK        – done / verified ("ok" in the sheet)
///   PENDING   – not yet done ("x" in the sheet)
///   ATTENTION – flagged, needs follow-up ("!" in the sheet)
///   NA        – not applicable to this role (blank in the sheet)
enum ChecklistItemStatus {
  OK
  PENDING
  ATTENTION
  NA
}

/// Level of an org-board node inside its revision. All nodes share
/// a single self-referencing table; `kind` disambiguates rendering
/// and drives which parents/children are allowed. Modelled after
/// L. Ron Hubbard's classic 7-division org board.
///   CROWN      – Founder / Executive Director / Deputy / VP.
///                Sits above the divisions; typically a linear chain.
///   DIVISION   – One of the 7 coloured columns.
///   DEPARTMENT – Standard Hubbard dept (1-21) inside a division.
///   SECTION    – A named group inside a department (optional).
///   UNIT       – A sub-group inside a section (optional, rare).
///   POSITION   – A role that a single Employee can hold. Positions
///                may nest under any of the above levels.
enum OrgNodeKind {
  CROWN
  DIVISION
  DEPARTMENT
  SECTION
  UNIT
  POSITION
}

/// Employment classification for a Position assignment. Broad enough
/// to cover contractors and interns while staying a small enum so
/// filters and reports can stay typed.
enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
  ADVISORY
}

/// Kinds of changes we log on the org board. Kept small on purpose;
/// finer distinctions live in the `newValue` JSON payload.
enum OrgAuditAction {
  NODE_CREATED
  NODE_UPDATED
  NODE_MOVED
  NODE_DELETED
  ASSIGNMENT_ADDED
  ASSIGNMENT_ENDED
}

// ============================================
// USER MANAGEMENT
// ============================================

model User {
  id                      String    @id @default(uuid())
  authId                  String?   @unique @map("auth_id") // Supabase auth.users.id
  email                   String    @unique
  name                    String?
  avatarUrl               String?   @map("avatar_url")
  /// Legacy global role. Being phased out in favour of
  /// CompanyMembership.role once every code path reads the active
  /// company's membership. Kept for Phase 1 so nothing else breaks.
  role                    Role      @default(MEMBER)
  /// Global super-admin flag. Grants the ability to enter any
  /// Company as a super-admin (Keanu at the agency level).
  /// Independent of memberships — the master key.
  isSuperAdmin            Boolean   @default(false) @map("is_super_admin")
  isActive                Boolean   @default(true) @map("is_active")
  emailVerified           Boolean   @default(false) @map("email_verified")
  lastLoginAt             DateTime? @map("last_login_at")
  /// Stamped by getUser() on every authenticated page request,
  /// debounced to once per 15 minutes per user. Powers the "Last
  /// active" column on /admin/team and /admin/members so the value
  /// reflects any URL access, not just explicit sign-in.
  lastActiveAt            DateTime? @map("last_active_at")
  /**
   * When the member last opened the announcements feed. Powers the
   * "New since your last visit" divider; updated server-side when
   * /announcements renders.
   */
  announcementsLastSeenAt DateTime? @map("announcements_last_seen_at")
  /**
   * Per-user notification opt-out. Defaults true so current behaviour
   * is preserved; members can disable from the preferences page.
   */
  notifyAnnouncementEmail Boolean   @default(true) @map("notify_announcement_email")
  /**
   * Optional category tier. When set, the member sees published
   * courses that either share this category, are marked isFree, or
   * have no categories at all. ADMIN/TEAM roles bypass the check.
   * Null = no tier assigned; member only sees free + uncategorized.
   */
  categoryId              String?   @map("category_id")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")
  deletedAt               DateTime? @map("deleted_at")

  // Relations
  category              Category?              @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  enrollments           Enrollment[]
  lessonProgress        LessonProgress[]
  quizAttempts          QuizAttempt[]
  notes                 Note[]
  announcementReads     AnnouncementRead[]
  announcementsAuthored Announcement[]         @relation("AnnouncementAuthor")
  announcementComments  AnnouncementComment[]
  announcementReactions AnnouncementReaction[]
  announcementAuditLogs AnnouncementAuditLog[]
  invites               Invite[]
  loginEvents           LoginEvent[]
  appSettingsUpdated    AppSetting[]           @relation("AppSettingUpdater")
  certificateIssuances  CertificateIssuance[]
  certsManuallyIssued   CertificateIssuance[]  @relation("CertsManuallyIssued")
  certsRevoked          CertificateIssuance[]  @relation("CertsRevoked")
  nudgesReceived        Nudge[]                @relation("NudgeRecipient")
  nudgesAuthored        Nudge[]                @relation("NudgeAuthor")
  statMetricsAssigned   StatMetric[]           @relation("StatMetricAssignee")
  statDataPointsAdded   StatDataPoint[]        @relation("StatDataPointAuthor")
  employee              Employee?              @relation("EmployeeUser")
  orgBoardRevisions     OrgBoardRevision[]     @relation("OrgBoardRevisionAuthor")
  orgAuditLogs          OrgNodeAuditLog[]      @relation("OrgAuditActor")
  companyMemberships    CompanyMembership[]

  // Super-admin grants — Phase 4.4 replaced the User.isSuperAdmin
  // boolean with a proper table so we get an audit trail + tiered
  // roles + expiration. The boolean column stays for now as a hot-
  // path cache; every grant/revoke writes to both places.
  superAdminGrantsHeld    SuperAdminGrant[] @relation("SuperAdminGrantTarget")
  superAdminGrantsIssued  SuperAdminGrant[] @relation("SuperAdminGrantGrantedBy")
  superAdminGrantsRevoked SuperAdminGrant[] @relation("SuperAdminGrantRevokedBy")

  @@index([role])
  @@index([isActive])
  @@index([deletedAt])
  @@index([isSuperAdmin])
  @@map("users")
}

// ============================================
// SUPER-ADMIN GRANTS
// ============================================

enum SuperAdminRole {
  /// Full platform power. Master key. Can create/delete companies,
  /// grant + revoke other super-admins, enter any tenant.
  MASTER
  /// Read-write inside any tenant, but cannot delete companies or
  /// grant super-admin. Future — used for Kondense support staff.
  SUPPORT
  /// Read-only across every tenant. Future — analytics + audit
  /// personas that need visibility without action.
  AUDITOR
}

/// Grants the super-admin master key to a user. One user can have
/// many rows over time (grant → revoke → re-grant); only one row
/// with revokedAt IS NULL is legal at any given moment.
///
/// The User.isSuperAdmin boolean is kept in sync as a hot-path
/// cache — gate checks read the boolean, not this table. Phase 7
/// drops the boolean once every reader has been switched over.
model SuperAdminGrant {
  id          String         @id @default(uuid())
  userId      String         @map("user_id")
  role        SuperAdminRole @default(MASTER)
  /// Who granted the flag. Null when the row was seeded via SQL
  /// during a migration (pre-4.4 backfill, break-glass).
  grantedById String?        @map("granted_by_id")
  grantedAt   DateTime       @default(now()) @map("granted_at")
  /// Optional expiry — after this instant the grant is treated as
  /// revoked by the hot-path check. Null = never expires.
  expiresAt   DateTime?      @map("expires_at")
  revokedAt   DateTime?      @map("revoked_at")
  revokedById String?        @map("revoked_by_id")
  /// Free-form justification: ticket #, requester name, etc. Kept
  /// short (255 char cap enforced app-side).
  notes       String?

  user      User  @relation("SuperAdminGrantTarget", fields: [userId], references: [id], onDelete: Cascade)
  grantedBy User? @relation("SuperAdminGrantGrantedBy", fields: [grantedById], references: [id], onDelete: SetNull)
  revokedBy User? @relation("SuperAdminGrantRevokedBy", fields: [revokedById], references: [id], onDelete: SetNull)

  @@index([userId, revokedAt])
  @@index([expiresAt])
  @@map("super_admin_grants")
}

// ============================================
// COMPANIES  (multi-tenancy — see docs/multi-tenancy.md)
// ============================================

/// A tenant. Every company sees only its own courses, members,
/// stats, certificates, etc. Users can belong to many companies
/// via CompanyMembership.
///
/// The seed row on migration is "Kondense" — all existing data is
/// backfilled to belong to it, so pre-tenancy accounts land
/// exactly where they were before.
model Company {
  id           String    @id @default(uuid())
  slug         String    @unique
  name         String
  /// True only for the Kondense parent row today. Not load-bearing
  /// for auth (super-admin is a global flag on User); reserved for
  /// future cross-tenant analytics anchoring.
  isAgency     Boolean   @default(false) @map("is_agency")
  /// White-label config: logo, favicon, primary + accent colors,
  /// product name shown in the sidebar, email `from` name, etc.
  /// Shape validated at the application layer (Phase 5).
  brand        Json?
  /// Custom domain e.g. "stephenagency.com". Nullable while a
  /// tenant is still on a subdomain. Verified + issued via Vercel
  /// in Phase 6.
  customDomain String?   @unique @map("custom_domain")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  memberships CompanyMembership[]

  @@index([deletedAt])
  @@map("companies")
}

/// Join row between User and Company. Carries the user's role
/// inside that specific company. One user can be OWNER in A,
/// MEMBER in B, ADMIN in C.
model CompanyMembership {
  id        String      @id @default(uuid())
  userId    String      @map("user_id")
  companyId String      @map("company_id")
  role      CompanyRole @default(MEMBER)
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([companyId, role])
  @@map("company_memberships")
}

// ============================================
// APP SETTINGS
// ============================================

/// Generic key-value store for admin-configurable platform settings
/// (e.g. Discord webhook URL, future integration tokens, branding).
/// One row per key. Reads are server-only — secret values must never
/// be returned to the client unmasked.
model AppSetting {
  key         String   @id
  value       String
  updatedAt   DateTime @updatedAt @map("updated_at")
  updatedById String?  @map("updated_by_id")
  updatedBy   User?    @relation("AppSettingUpdater", fields: [updatedById], references: [id], onDelete: SetNull)

  companyId String @default("00000000-0000-0000-0000-000000000001") @map("company_id")

  @@map("app_settings")
}

// ============================================
// INVITES
// ============================================

/// Admin-issued onboarding tokens. New members receive a link that
/// embeds the token; the onboarding flow consumes it once to set
/// their initial password.
model Invite {
  id            String    @id @default(uuid())
  token         String    @unique
  userId        String    @map("user_id")
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt     DateTime  @map("expires_at")
  // Set once the password step succeeds. Used to allow re-entry into
  // the wizard for the same authenticated user while keeping anyone
  // else from re-setting the password.
  passwordSetAt DateTime? @map("password_set_at")
  // Set once the final wizard step is reached. After this the link is
  // dead and the "Invite invalid" screen takes over.
  usedAt        DateTime? @map("used_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  companyId     String    @default("00000000-0000-0000-0000-000000000001") @map("company_id")

  @@index([userId])
  @@index([token])
  @@map("invites")
}

// ============================================
// LOGIN EVENTS
// ============================================

/// Tracks individual login timestamps per user. Powers the activity
/// sparkline on the admin members page.
model LoginEvent {
  id      String   @id @default(uuid())
  userId  String   @map("user_id")
  loginAt DateTime @default(now()) @map("login_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, loginAt])
  @@map("login_events")
}

// ============================================
// COURSE STRUCTURE
// ============================================

model Course {
  id                     String         @id @default(uuid())
  title                  String
  // URL-safe identifier used on both public and admin pages. Unique.
  // Auto-derived from title when the admin leaves the field blank;
  // editable for SEO tuning. See lib/utils/slug.ts for generation.
  slug                   String         @unique
  description            String?
  thumbnailUrl           String?        @map("thumbnail_url")
  // Wide 16:9 hero image used on the course detail page. Optional —
  // detail pages fall back to a gradient placeholder when null.
  coverImageUrl          String?        @map("cover_image_url")
  status                 CourseStatus   @default(DRAFT)
  // When true, any signed-in MEMBER can open the course without an
  // Enrollment row. Paid courses leave this false and continue to
  // require enrollment for access. Only meaningful when audience
  // includes MEMBERS (i.e. MEMBERS or BOTH).
  isFree                 Boolean        @default(false) @map("is_free")
  // Who sees this course beyond admins. See CourseAudience for
  // semantics. Defaults to MEMBERS for backwards compatibility.
  audience               CourseAudience @default(MEMBERS)
  orderIndex             Int            @default(0) @map("order_index")
  accessDays             Int?           @map("access_days") // null = forever
  // When true, members who complete this course can download a
  // personalised PDF certificate generated from scratch (Kondense-
  // branded layout in lib/services/certificate-service.ts). Off by
  // default — admins opt in per course so a 10-minute intro doesn't
  // accidentally award a cert.
  certificateEnabled     Boolean        @default(false) @map("certificate_enabled")
  // Deprecated: lingers from the earlier "stamp text onto admin-
  // uploaded template" approach. Replaced by the from-scratch
  // generator; the field is harmless but unused. Safe to drop in a
  // later migration once we're sure we don't want a custom-template
  // override.
  certificateTemplateUrl String?        @map("certificate_template_url")
  publishedAt            DateTime?      @map("published_at")
  createdBy              String?        @map("created_by")
  createdAt              DateTime       @default(now()) @map("created_at")
  updatedAt              DateTime       @updatedAt @map("updated_at")
  deletedAt              DateTime?      @map("deleted_at")

  // Relations
  chapters             Chapter[]
  modules              Module[]
  enrollments          Enrollment[]
  categories           CourseCategory[]
  certificateIssuances CertificateIssuance[]
  nudges               Nudge[]
  companyId            String                @default("00000000-0000-0000-0000-000000000001") @map("company_id")

  @@index([status])
  @@index([deletedAt])
  @@index([orderIndex])
  @@map("courses")
}

/// Flat tag-style grouping for courses. Admins manage these in
/// /admin/categories; courses join via the CourseCategory pivot.
/// `slug` powers any future /categories/[slug] browse page.
model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  courses CourseCategory[]
  members User[]

  companyId String @default("00000000-0000-0000-0000-000000000001") @map("company_id")

  @@map("categories")
}

/// Junction row connecting a course to a category. Composite PK
/// guarantees a single (course, category) edge. Both sides cascade
/// on delete so removing a category cleans up its memberships.
model CourseCategory {
  courseId   String   @map("course_id")
  categoryId String   @map("category_id")
  createdAt  DateTime @default(now()) @map("created_at")

  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  category  Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  companyId String   @default("00000000-0000-0000-0000-000000000001") @map("company_id")

  @@id([courseId, categoryId])
  @@index([categoryId])
  @@map("course_categories")
}

/// Optional grouping layer between Course and Chapter. A course may
/// have any number of modules; chapters may sit directly on a course
/// (moduleId = null) OR under a module. Modules and loose chapters
/// share the same top-level ordering space (orderIndex on the course).
model Module {
  id          String    @id @default(uuid())
  courseId    String    @map("course_id")
  title       String
  description String?
  orderIndex  Int       @default(0) @map("order_index")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  // Relations
  course               Course                @relation(fields: [courseId], references: [id], onDelete: Cascade)
  chapters             Chapter[]
  certificateIssuances CertificateIssuance[]
  companyId            String                @default("00000000-0000-0000-0000-000000000001") @map("company_id")

  @@index([courseId, orderIndex])
  @@index([deletedAt])
  @@map("modules")
}

model Chapter {
  id         String    @id @default(uuid())
  courseId   String    @map("course_id")
  // Optional parent module. Null means the chapter sits directly on
  // the course (a "loose" chapter). courseId stays denormalized so
  // RLS and ordering queries don't need to traverse the module.
  moduleId   String?   @map("module_id")
  title      String
  orderIndex Int       @default(0) @map("order_index")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  // Relations. Module delete uses SetNull so removing a module turns
  // its chapters into loose chapters on the same course rather than
  // cascading the delete down.
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  module    Module?  @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  lessons   Lesson[]
  companyId String   @default("00000000-0000-0000-0000-000000000001") @map("company_id")

  @@index([courseId, orderIndex])
  @@index([moduleId, orderIndex])
  @@map("chapters")
}

model Lesson {
  id          String       @id @default(uuid())
  chapterId   String       @map("chapter_id")
  title       String
  type        LessonType
  status      LessonStatus @default(DRAFT)
  orderIndex  Int          @default(0) @map("order_index")
  description String?

  // Video fields (type = VIDEO)
  muxAssetId      String? @map("mux_asset_id")
  muxPlaybackId   String? @map("mux_playback_id")
  durationSeconds Int?    @map("duration_seconds")

  // Quiz settings (type = QUIZ)
  passingScore Int? @map("passing_score") // Minimum % to pass (e.g., 70)
  maxAttempts  Int? @map("max_attempts") // null = unlimited
  timeLimitMin Int? @map("time_limit_min") // null = no limit

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // Relations
  chapter        Chapter          @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  quizQuestions  QuizQuestion[]
  lessonProgress LessonProgress[]
  quizAttempts   QuizAttempt[]
  notes          Note[]
  resources      LessonResource[]
  companyId      String           @default("00000000-0000-0000-0000-000000000001") @map("company_id")

  @@index([chapterId, orderIndex])
  @@index([type])
  @@index([status])
  @@map("lessons")
}

/// Files attached to a lesson (PDFs, worksheets, slides, etc.).
/// Stored in the `lesson-resources` Supabase Storage bucket at path
/// `<lessonId>/<resourceId>`. Original filename + mime type live in
/// the row so signed-download URLs can serve the correct attachment.
model LessonResource {
  id        String   @id @default(uuid())
  lessonId  String   @map("lesson_id")
  name      String // Original filename, e.g. "workbook.pdf"
  path      String // Bucket-relative path, e.g. "<lessonId>/<resourceId>"
  size      Int // Bytes
  mimeType  String   @map("mime_type")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  lesson    Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  companyId String @default("00000000-0000-0000-0000-000000000001") @map("company_id")

  @@index([lessonId, createdAt])
  @@map("lesson_resources")
}

// ============================================
// QUIZ SYSTEM
// ============================================

model QuizQuestion {
  id           String       @id @default(uuid())
  lessonId     String       @map("lesson_id")
  questionText String       @map("question_text")
  type         QuestionType
  options      Json // ["Option A", "Option B", ...] or ["True", "False"]
  correctIndex Int          @map("correct_index") // Index of correct option
  explanation  String? // Shown after answering
  orderIndex   Int          @default(0) @map("order_index")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  // Relations
  lesson    Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  companyId String @default("00000000-0000-0000-0000-000000000001") @map("company_id")

  @@index([lessonId, orderIndex])
  @@map("quiz_questions")
}

model QuizAttempt {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  lessonId  String   @map("lesson_id")
  score     Int // Number correct
  total     Int // Total questions
  passed    Boolean  @default(false)
  answers   Json // { questionId: selectedIndex, ... }
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson    Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  companyId String @default("00000000-0000-0000-0000-000000000001") @map("company_id")

  @@index([userId, lessonId, createdAt])
  @@map("quiz_attempts")
}

// ============================================
// USER PROGRESS
// ============================================

model Enrollment {
  id              String           @id @default(uuid())
  userId          String           @map("user_id")
  courseId        String           @map("course_id")
  status          EnrollmentStatus @default(ACTIVE)
  source          EnrollmentSource @default(MANUAL)
  progressPercent Int              @default(0) @map("progress_percent") // Cached 0-100
  enrolledAt      DateTime         @default(now()) @map("enrolled_at")
  lastAccessedAt  DateTime?        @map("last_accessed_at")
  expiresAt       DateTime?        @map("expires_at")
  completedAt     DateTime?        @map("completed_at")
  revokedAt       DateTime?        @map("revoked_at")
  revokedReason   String?          @map("revoked_reason")

  // Relations
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  companyId String @default("00000000-0000-0000-0000-000000000001") @map("company_id")

  @@unique([userId, courseId])
  @@index([userId, status])
  @@index([courseId, status])
  @@index([expiresAt])
  @@map("enrollments")
}

model LessonProgress {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  lessonId        String    @map("lesson_id")
  completed       Boolean   @default(false)
  completedAt     DateTime? @map("completed_at")
  watchedPercent  Int       @default(0) @map("watched_percent") // 0-100
  lastPositionSec Int       @default(0) @map("last_position_sec") // Resume position
  watchCount      Int       @default(0) @map("watch_count")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson    Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  companyId String @default("00000000-0000-0000-0000-000000000001") @map("company_id")

  @@unique([userId, lessonId])
  @@index([userId, completed])
  @@map("lesson_progress")
}

// ============================================
// CERTIFICATES
// ============================================

/// One row per (user, module) once the member has completed every
/// lesson in that module. The presence of a row IS the eligibility
/// signal — the PDF itself is rendered lazily on first download and
/// cached in the `course-certificates` Storage bucket under the
/// issuance id. shortCode is the public-facing identifier shown on
/// the PDF (random base32, retried on collision).
model CertificateIssuance {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  moduleId  String   @map("module_id")
  /// Denormalised so listing a member's certificates can join straight
  /// to the course without traversing module → course.
  courseId  String   @map("course_id")
  shortCode String   @unique @map("short_code")
  issuedAt  DateTime @default(now()) @map("issued_at")
  createdAt DateTime @default(now()) @map("created_at")

  /// Admin who bypassed the module-completion gate to hand-issue this
  /// certificate. Null for auto-issued rows (the default path).
  manuallyIssuedById String? @map("manually_issued_by_id")

  /// Revocation trio. Set together by an admin action; presence of
  /// revokedAt is the "is revoked" signal. Member-side list + download
  /// filter these out; the auto-issue hook also treats a revoked row
  /// as "already handled" so a re-completion doesn't silently re-issue.
  revokedAt     DateTime? @map("revoked_at")
  revokedById   String?   @map("revoked_by_id")
  revokedReason String?   @map("revoked_reason")

  user             User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  module           Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  course           Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  manuallyIssuedBy User?  @relation("CertsManuallyIssued", fields: [manuallyIssuedById], references: [id], onDelete: SetNull)
  revokedBy        User?  @relation("CertsRevoked", fields: [revokedById], references: [id], onDelete: SetNull)
  companyId        String @default("00000000-0000-0000-0000-000000000001") @map("company_id")

  @@unique([userId, moduleId])
  @@index([userId, issuedAt])
  @@index([courseId])
  @@index([revokedAt])
  @@map("certificate_issuances")
}

// ============================================
// NUDGES
// ============================================

/// Admin-authored re-engagement message aimed at a specific member.
/// Delivered as a Resend email at create time AND rendered as a
/// dismissible banner on the member's next dashboard visit. Dismissal
/// stamps dismissedAt so the banner disappears; the row itself
/// persists as an audit trail (admin can see "was this nudge shown").
model Nudge {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  /// Optional target course — if set, the email + banner CTAs deep-
  /// link there ("Resume <course>"). Null means a generic nudge back
  /// to the dashboard.
  courseId    String?   @map("course_id")
  message     String
  createdById String    @map("created_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  /// Populated when Resend confirms the send. Null = email queue
  /// failed; the banner still shows so the nudge isn't wasted.
  emailSentAt DateTime? @map("email_sent_at")
  /// Set when the member clicks Dismiss on the banner. Also cleared
  /// implicitly when the member finishes the target course.
  dismissedAt DateTime? @map("dismissed_at")

  user      User    @relation("NudgeRecipient", fields: [userId], references: [id], onDelete: Cascade)
  course    Course? @relation(fields: [courseId], references: [id], onDelete: SetNull)
  createdBy User    @relation("NudgeAuthor", fields: [createdById], references: [id], onDelete: Restrict)
  companyId String  @default("00000000-0000-0000-0000-000000000001") @map("company_id")

  @@index([userId, dismissedAt])
  @@index([createdAt])
  @@map("nudges")
}

// ============================================
// LESSON NOTES
// ============================================

model Note {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  lessonId  String   @map("lesson_id")
  content   String   @default("")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson    Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  companyId String @default("00000000-0000-0000-0000-000000000001") @map("company_id")

  @@unique([userId, lessonId])
  @@map("notes")
}

// ============================================
// ANNOUNCEMENTS
// ============================================

model Announcement {
  id          String               @id @default(uuid())
  title       String
  body        String
  status      AnnouncementStatus   @default(DRAFT)
  category    AnnouncementCategory @default(GENERAL)
  publishedAt DateTime?            @map("published_at")
  /**
   * When set, a cron flips status to PUBLISHED at or after this
   * time. Cleared when the row is actually published.
   */
  scheduledAt DateTime?            @map("scheduled_at")
  /**
   * Hidden from the member feed once set. Reads-analytics rows
   * stay around — the row itself is preserved.
   */
  archivedAt  DateTime?            @map("archived_at")
  /**
   * Sticky pin keeps this row above un-pinned rows in both the
   * member feed and the admin list, regardless of publishedAt.
   */
  pinned      Boolean              @default(false)
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")
  deletedAt   DateTime?            @map("deleted_at")
  // Author. Nullable + onDelete: SetNull so deleting an admin
  // doesn't cascade away every announcement they wrote.
  createdBy   String?              @map("created_by")

  // Relations
  reads         AnnouncementRead[]
  comments      AnnouncementComment[]
  reactions     AnnouncementReaction[]
  auditLogs     AnnouncementAuditLog[]
  createdByUser User?                  @relation("AnnouncementAuthor", fields: [createdBy], references: [id], onDelete: SetNull)
  companyId     String                 @default("00000000-0000-0000-0000-000000000001") @map("company_id")

  @@index([status])
  @@index([deletedAt])
  @@index([createdBy])
  @@index([archivedAt])
  @@index([scheduledAt])
  @@index([pinned])
  @@map("announcements")
}

model AnnouncementRead {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  announcementId String   @map("announcement_id")
  readAt         DateTime @default(now()) @map("read_at")

  // Relations
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  companyId    String       @default("00000000-0000-0000-0000-000000000001") @map("company_id")

  @@unique([userId, announcementId])
  @@index([userId])
  @@map("announcement_reads")
}

model AnnouncementComment {
  id             String    @id @default(uuid())
  announcementId String    @map("announcement_id")
  userId         String    @map("user_id")
  body           String
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  /**
   * Soft delete so admins can audit who deleted what.
   */
  deletedAt      DateTime? @map("deleted_at")

  // Relations
  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId    String       @default("00000000-0000-0000-0000-000000000001") @map("company_id")

  @@index([announcementId, createdAt])
  @@index([userId])
  @@index([deletedAt])
  @@map("announcement_comments")
}

model AnnouncementReaction {
  id             String   @id @default(uuid())
  announcementId String   @map("announcement_id")
  userId         String   @map("user_id")
  /**
   * Emoji literal, e.g. "👍". One emoji per row, multiple rows per
   * user allowed (you can react with multiple emojis), but each
   * (announcement, user, emoji) triple is unique so the same user
   * can't double-react with the same emoji.
   */
  emoji          String
  createdAt      DateTime @default(now()) @map("created_at")

  // Relations
  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId    String       @default("00000000-0000-0000-0000-000000000001") @map("company_id")

  @@unique([announcementId, userId, emoji])
  @@index([announcementId])
  @@index([userId])
  @@map("announcement_reactions")
}

model AnnouncementAuditLog {
  id             String                  @id @default(uuid())
  announcementId String                  @map("announcement_id")
  /**
   * Actor. Nullable + SetNull so deleting an admin doesn't wipe
   * the audit trail.
   */
  userId         String?                 @map("user_id")
  action         AnnouncementAuditAction
  /**
   * Optional payload — e.g. the diff or a snapshot of what changed.
   * Stored as JSON so future actions can attach richer context
   * without a schema migration.
   */
  metadata       Json?
  createdAt      DateTime                @default(now()) @map("created_at")

  // Relations
  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  companyId    String       @default("00000000-0000-0000-0000-000000000001") @map("company_id")

  @@index([announcementId, createdAt])
  @@index([userId])
  @@map("announcement_audit_logs")
}

/**
 * Fixed-window per-IP rate limit counter. Each row tracks the number
 * of times a given IP hit a given action within a specific window
 * (window_start = floor(now / window_seconds) * window_seconds).
 * Caller composes the key + window size; this table only stores the
 * counter. Old rows are not auto-deleted — a periodic cron should
 * prune entries where window_start < now() - 1 day.
 * Primary use: brute-force protection on auth flows (sign-in, sign-
 * up, password reset, onboarding password-set).
 */
model RateLimit {
  id          String   @id @default(uuid())
  /**
   * The originating IP. From x-forwarded-for header on Vercel.
   */
  ip          String
  /**
   * Action key — e.g. "auth:sign-in", "auth:reset-password".
   */
  action      String
  /**
   * UTC start of the bucket window this row counts requests in.
   */
  windowStart DateTime @map("window_start")
  count       Int      @default(1)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([ip, action, windowStart])
  @@index([windowStart])
  @@map("rate_limits")
}

// ============================================
// INTERNAL — EMPLOYEE ONBOARDING
// ============================================

/// Internal HR record for a hire (contractor or staff). Distinct from
/// `User` because most people we onboard never touch the SaaS login —
/// only a small subset (the admin + internal team who use this tool)
/// also have a User row. When they do, `userId` links the two so we
/// can dedupe by identity later.
model Employee {
  id              String           @id @default(uuid())
  /// Optional link to the SaaS user account, if this hire also uses
  /// the platform. SetNull keeps the HR record intact if the User is
  /// ever deleted.
  userId          String?          @unique @map("user_id")
  name            String
  /// Free-text job title from the sheet ("SaaS Developer", "Video
  /// Editor", etc). Not an enum — the org keeps inventing new roles.
  roleTitle       String           @map("role_title")
  status          EmploymentStatus @default(ACTIVE)
  /// Day the hire signed / was formally onboarded.
  onboardingDate  DateTime?        @map("onboarding_date")
  /// Day they actually began work. Often days/weeks after onboarding.
  dateStarted     DateTime?        @map("date_started")
  /// Set together with `status = OFFBOARDED`.
  offboardingDate DateTime?        @map("offboarding_date")
  /// Free-text notes from HR (why they left, gotchas, etc).
  notes           String?
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  user                User?                         @relation("EmployeeUser", fields: [userId], references: [id], onDelete: SetNull)
  checklistStatuses   EmployeeChecklistItemStatus[]
  orgAssignments      OrgNode[]                     @relation("OrgNodeEmployee")
  positionAssignments PositionAssignment[]          @relation("EmployeePositionAssignments")
  companyId           String                        @default("00000000-0000-0000-0000-000000000001") @map("company_id")

  @@index([status])
  @@index([roleTitle])
  @@index([onboardingDate])
  @@map("employees")
}

/// One row per task in the (single, global) onboarding checklist.
/// Order matters for display and is preserved via `orderIndex`
/// (0-based, unique across all rows). Every Employee is
/// implicitly attached to the same list — the multi-template
/// abstraction that used to live here was cut in favour of a flat
/// model. Statuses reference items directly.
model OnboardingChecklistItem {
  id          String   @id @default(uuid())
  label       String
  description String?
  /// Display order across the whole checklist (0-based, unique).
  orderIndex  Int      @unique @map("order_index")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  statuses EmployeeChecklistItemStatus[]

  companyId String @default("00000000-0000-0000-0000-000000000001") @map("company_id")

  @@map("onboarding_checklist_items")
}

/// The per-employee state for a single checklist item. Absent row =
/// same as "no status yet"; the UI treats missing rows as NA so we
/// only write rows once an admin actually touches an item. `note` is
/// optional free-text (e.g. "waiting on IT for Gdrive access").
model EmployeeChecklistItemStatus {
  id          String              @id @default(uuid())
  employeeId  String              @map("employee_id")
  itemId      String              @map("item_id")
  status      ChecklistItemStatus @default(PENDING)
  note        String?
  completedAt DateTime?           @map("completed_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  employee  Employee                @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  item      OnboardingChecklistItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  companyId String                  @default("00000000-0000-0000-0000-000000000001") @map("company_id")

  @@unique([employeeId, itemId])
  @@index([employeeId])
  @@index([itemId])
  @@index([status])
  @@map("employee_checklist_item_statuses")
}

// ============================================
// INTERNAL — ORG BOARD (Hubbard 7-division)
// ============================================

/// A named snapshot of the whole org structure. Exactly one row
/// should carry `isCurrent = true` at any moment — the live board
/// admins see and edit. Older revisions are read-only history so
/// admins can compare "who was where in Q2 vs Q3". The service
/// layer enforces "one current" via transaction; callers should
/// still treat multiple currents as "any is fine" defensively.
model OrgBoardRevision {
  id          String    @id @default(uuid())
  name        String
  description String?
  isCurrent   Boolean   @default(false) @map("is_current")
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  createdById String?   @map("created_by_id")
  createdBy   User?     @relation("OrgBoardRevisionAuthor", fields: [createdById], references: [id], onDelete: SetNull)

  nodes     OrgNode[]
  auditLogs OrgNodeAuditLog[]
  companyId String            @default("00000000-0000-0000-0000-000000000001") @map("company_id")

  @@index([isCurrent])
  @@map("org_board_revisions")
}

/// One node in an org-board tree. Everything from the Founder box
/// down to a single position lives here — `kind` disambiguates
/// rendering. Trees are per-revision (revisionId), and moving a
/// node just changes its parentId. Cascade on parent delete so
/// removing a division cleanly wipes its descendants.
model OrgNode {
  id               String      @id @default(uuid())
  revisionId       String      @map("revision_id")
  parentId         String?     @map("parent_id")
  kind             OrgNodeKind
  /// Header text shown on the card (e.g. "Division 2 - Sales &
  /// Marketing" or "Founder" or "Recognition - Department 1").
  label            String
  /// Optional Hubbard-style dept number 1-21. Kept as a plain int
  /// so custom departments outside the classic 21 are still
  /// representable.
  deptNumber       Int?        @map("dept_number")
  /// The role/title displayed under the label — e.g. "Sales &
  /// Marketing Director" or "Video Editor". Used for POSITION
  /// nodes and for any header node that has a designated role.
  positionTitle    String?     @map("position_title")
  /// The Employee currently holding this node's role. Only
  /// meaningful for POSITION and DIVISION/DEPARTMENT-level roles.
  /// SetNull so offboarding an employee blanks the seat without
  /// destroying the org structure.
  employeeId       String?     @map("employee_id")
  /// Free-text fallback for people who aren't (yet) Employees.
  /// Handy for "To be hired" placeholders. Ignored when
  /// `employeeId` is set.
  freeTextHolder   String?     @map("free_text_holder")
  /// Free-text description of what this node/role does. Applies at
  /// any level (a Division has a Function; a Position has one too).
  functionText     String?     @map("function_text")
  /// Bullet list of the node's responsibilities. Stored as a
  /// Postgres text[] so we don't have to marshal JSON on the client.
  responsibilities String[]    @default([])
  /// Free-text notes (admin-only).
  notes            String?
  /// Optional Tailwind-safe colour token override. Divisions have
  /// a default palette so this can stay null for the common case.
  color            String?
  /// Sibling order within the same parent. Zero-based; unique
  /// only within (revisionId, parentId).
  orderIndex       Int         @map("order_index")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  revision       OrgBoardRevision     @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  parent         OrgNode?             @relation("OrgNodeParent", fields: [parentId], references: [id], onDelete: Cascade)
  children       OrgNode[]            @relation("OrgNodeParent")
  employee       Employee?            @relation("OrgNodeEmployee", fields: [employeeId], references: [id], onDelete: SetNull)
  positionDetail PositionDetail?
  assignments    PositionAssignment[]
  auditLogs      OrgNodeAuditLog[]
  companyId      String               @default("00000000-0000-0000-0000-000000000001") @map("company_id")

  @@index([revisionId])
  @@index([parentId])
  @@index([kind])
  @@index([employeeId])
  @@map("org_nodes")
}

/// Position-specific attributes kept in a sidecar table so the main
/// tree stays lean. 1:1 with OrgNode; only rows of kind POSITION or
/// DIVISION/DEPARTMENT that have a formal role head will have one.
/// Missing PositionDetail means "no structured detail yet" — the
/// admin can add later.
model PositionDetail {
  id             String          @id @default(uuid())
  nodeId         String          @unique @map("node_id")
  /// Human-readable identifier (e.g. "POS-004" or "ENG-DIR"). No
  /// uniqueness constraint at the DB layer — organisations sometimes
  /// reuse codes across divisions on purpose.
  code           String?
  /// Numeric seniority. Convention: 1 = executive, 10 = individual
  /// contributor. Nullable because plenty of positions don't slot
  /// neatly onto a linear ladder.
  level          Int?
  /// Headcount range for this seat. Both nullable because most
  /// positions have exactly one holder — the fields matter when a
  /// role is scaled (e.g. "3-5 Appointment Setters in this unit").
  headcountMin   Int?            @map("headcount_min")
  headcountMax   Int?            @map("headcount_max")
  employmentType EmploymentType? @map("employment_type")
  /// Position-specific KPIs.
  kpis           String[]        @default([])
  /// Position-specific qualifications.
  requirements   String[]        @default([])
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  node      OrgNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  companyId String  @default("00000000-0000-0000-0000-000000000001") @map("company_id")

  @@index([code])
  @@map("position_details")
}

/// Records an employee holding a position. Multiple rows per node
/// support the "multiple Video Editors" pattern from the Makh org
/// board. An assignment ends when `endedAt` is set; querying "who
/// currently holds this seat" filters `endedAt = null`.
model PositionAssignment {
  id             String          @id @default(uuid())
  nodeId         String          @map("node_id")
  employeeId     String          @map("employee_id")
  dateAssigned   DateTime        @default(now()) @map("date_assigned")
  endedAt        DateTime?       @map("ended_at")
  employmentType EmploymentType? @map("employment_type")
  notes          String?
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  node      OrgNode  @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  employee  Employee @relation("EmployeePositionAssignments", fields: [employeeId], references: [id], onDelete: Cascade)
  companyId String   @default("00000000-0000-0000-0000-000000000001") @map("company_id")

  @@index([nodeId, endedAt])
  @@index([employeeId, endedAt])
  @@map("position_assignments")
}

/// Append-only log of every mutation on the org board. `nodeId` is
/// nullable + SetNull so history survives after a node is deleted
/// (we still want to know "someone deleted Department X on this
/// date"). `oldValue` / `newValue` are free-form JSON so we can
/// stash whatever the mutation touched without a migration when the
/// service layer gains a new field.
model OrgNodeAuditLog {
  id          String         @id @default(uuid())
  revisionId  String         @map("revision_id")
  /// The node the change targeted. Null for post-deletion history.
  nodeId      String?        @map("node_id")
  /// User who initiated the change. Null when the change came from
  /// a service token or a background job.
  actorUserId String?        @map("actor_user_id")
  action      OrgAuditAction
  /// Freeze of the affected fields *before* the change (null for
  /// creates). Compact — we don't snapshot the whole node.
  oldValue    Json?
  /// Freeze of the affected fields *after* the change (null for
  /// pure deletes).
  newValue    Json?
  createdAt   DateTime       @default(now()) @map("created_at")

  revision  OrgBoardRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  node      OrgNode?         @relation(fields: [nodeId], references: [id], onDelete: SetNull)
  actor     User?            @relation("OrgAuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  companyId String           @default("00000000-0000-0000-0000-000000000001") @map("company_id")

  @@index([revisionId, createdAt])
  @@index([nodeId, createdAt])
  @@map("org_node_audit_logs")
}

// ============================================
// STATISTICS TRACKER
// ============================================

/// Unit of measurement stamped on a metric — informs how values are
/// formatted in the UI (e.g. "$1,234" vs "1,234" vs "82%"). Kept
/// small on purpose; edge cases can render raw counts.
enum StatMetricUnit {
  COUNT
  CURRENCY
  PERCENT
}

/// Divisions are the top-level grouping in the Hubbard-style stats
/// board (HCO, Marketing, Treasury, etc.). Admin-configurable so
/// each team can shape the taxonomy without a code change.
model StatDivision {
  id          String    @id @default(uuid())
  name        String
  /// Optional short label ("Div 1", "2A") shown above the name in
  /// tabs. Null falls back to a numeric position.
  shortLabel  String?   @map("short_label")
  description String?
  orderIndex  Int       @default(0) @map("order_index")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  metrics   StatMetric[]
  companyId String       @default("00000000-0000-0000-0000-000000000001") @map("company_id")

  @@index([orderIndex])
  @@index([deletedAt])
  @@map("stat_divisions")
}

/// A single metric card — one KPI tracked over time. Belongs to a
/// division and (optionally) has an assigned owner. The assigned
/// user + admins can add data points; everyone with admin/stat
/// access can view.
model StatMetric {
  id           String         @id @default(uuid())
  divisionId   String         @map("division_id")
  name         String
  description  String?
  unit         StatMetricUnit @default(COUNT)
  /// User accountable for the metric. Null = unassigned (still
  /// admin-editable). SetNull on user delete so history survives.
  assignedToId String?        @map("assigned_to_id")
  orderIndex   Int            @default(0) @map("order_index")
  /// Optional target value drawn as a horizontal reference line on
  /// the chart. Nullable — a lot of stats don't have hard targets.
  targetValue  Decimal?       @map("target_value") @db.Decimal(18, 4)
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  deletedAt    DateTime?      @map("deleted_at")

  division   StatDivision    @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  assignedTo User?           @relation("StatMetricAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  dataPoints StatDataPoint[]
  companyId  String          @default("00000000-0000-0000-0000-000000000001") @map("company_id")

  @@index([divisionId, orderIndex])
  @@index([assignedToId])
  @@index([deletedAt])
  @@map("stat_metrics")
}

/// One recorded value on a metric's time-series. recordedAt stores
/// the point-in-time this value represents (typically the end of a
/// week). (metricId, recordedAt) is unique so a per-week grain never
/// double-records — updating an existing week goes through upsert.
model StatDataPoint {
  id          String   @id @default(uuid())
  metricId    String   @map("metric_id")
  value       Decimal  @db.Decimal(18, 4)
  recordedAt  DateTime @map("recorded_at") @db.Date
  note        String?
  createdById String?  @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  metric    StatMetric @relation(fields: [metricId], references: [id], onDelete: Cascade)
  createdBy User?      @relation("StatDataPointAuthor", fields: [createdById], references: [id], onDelete: SetNull)
  companyId String     @default("00000000-0000-0000-0000-000000000001") @map("company_id")

  @@unique([metricId, recordedAt])
  @@index([metricId, recordedAt])
  @@map("stat_data_points")
}
