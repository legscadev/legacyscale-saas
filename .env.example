# Copy this file to .env.local and fill in values.
# In Vercel, set the same variables in Project Settings → Environment Variables.

# ─────────── Supabase ───────────
# Use the DEV project for Preview deploys, PROD project for Production.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# App runtime connection — use the Transaction-mode pooler URL (port 6543,
# pgbouncer=true) from Supabase → Settings → Database. The pg adapter in
# lib/prisma.ts uses this.
DATABASE_URL=
# Direct (non-pooled) connection on port 5432 — used by `prisma migrate`
# for DDL (pgbouncer's transaction-pooling mode breaks migrate's
# session-scoped commands). Same credentials/host as DATABASE_URL,
# just port 5432 with no ?pgbouncer=true. Set this in Vercel too.
DIRECT_URL=

# ─────────── Mux (video) ───────────
# From Mux dashboard → Settings → Access Tokens (per environment).
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
# Leave empty until you create the webhook in Mux dashboard
# (needs the deployed app URL → configured after first deploy).
MUX_WEBHOOK_SECRET=

# ─────────── Resend (email) ───────────
# From Resend dashboard → API Keys.
RESEND_API_KEY=
# Use onboarding@resend.dev for dev (sandbox; delivers to your account email only).
# Switch to a verified address like welcome@mail.kondense.ai after domain verification.
RESEND_FROM_EMAIL=onboarding@resend.dev

# ─────────── GoHighLevel webhook (Phase 1) ───────────
GHL_WEBHOOK_SECRET=

# ─────────── App URL ───────────
# Local: http://localhost:3000
# Vercel Preview: https://legacyscale-saas-git-develop-<your-team>.vercel.app
# Vercel Production: https://legacyscale-saas.vercel.app (or your custom domain)
NEXT_PUBLIC_APP_URL=http://localhost:3000
