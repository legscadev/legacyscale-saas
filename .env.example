# Copy this file to .env.local and fill in values.
# In Vercel, set the same variables in Project Settings → Environment Variables.

# ─────────── Supabase ───────────
# Use the DEV project for Preview deploys, PROD project for Production.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# App runtime connection — use the Transaction-mode pooler URL (port 6543,
# pgbouncer=true) from Supabase → Settings → Database. The pg adapter in
# lib/prisma.ts uses this.
DATABASE_URL=
# Direct (non-pooled) connection on port 5432 — used by `prisma migrate`
# for DDL (pgbouncer's transaction-pooling mode breaks migrate's
# session-scoped commands). Same credentials/host as DATABASE_URL,
# just port 5432 with no ?pgbouncer=true. Set this in Vercel too.
DIRECT_URL=
# Empty Postgres DB that `prisma migrate diff/dev` can drop/recreate
# to compute schema deltas. Local only — never used at runtime, never
# set in Vercel. Point at a scratch DB (local Postgres, Neon, etc.);
# NEVER point at dev or prod. Example:
#   SHADOW_DATABASE_URL=postgresql://<user>@127.0.0.1:5432/prisma_shadow
SHADOW_DATABASE_URL=

# ─────────── Mux (video) ───────────
# From Mux dashboard → Settings → Access Tokens (per environment).
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
# Leave empty until you create the webhook in Mux dashboard
# (needs the deployed app URL → configured after first deploy).
MUX_WEBHOOK_SECRET=

# ─────────── Resend (email) ───────────
# From Resend dashboard → API Keys.
RESEND_API_KEY=
# Use onboarding@resend.dev for dev (sandbox; delivers to your account email only).
# Switch to a verified address like welcome@mail.kondense.ai after domain verification.
RESEND_FROM_EMAIL=onboarding@resend.dev

# ─────────── GoHighLevel webhook (Phase 1) ───────────
GHL_WEBHOOK_SECRET=

# ─────────── App URL ───────────
# Local: http://localhost:3000
# Vercel Preview: https://legacyscale-saas-git-develop-<your-team>.vercel.app
# Vercel Production: https://legacyscale-saas.vercel.app (or your custom domain)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────── Multi-tenancy feature flag ───────────
# Off by default. Flip to 1 on develop once Phase 1 lands. Prod
# stays off until Phase 7 rollout. See docs/multi-tenancy.md.
TENANCY_ENABLED=0

# ─────────── Domains (Phase 3) ───────────
# Hostname the platform's own admin surface lives at, e.g.
# "app.kondense.ai" in prod, "test.kondense.ai" in staging.
# Falls back to "localhost:3000" for local dev.
PLATFORM_HOST=
# Apex domain that managed subdomains hang off of — e.g.
# "kondense.ai" so a tenant slug "acme" becomes "acme.kondense.ai".
# Falls back to "localhost" for local dev (Chrome + Firefox resolve
# *.localhost, so `acme.localhost:3000` just works in dev).
PLATFORM_APEX_DOMAIN=

# Vercel Domains API access — only needed on the deploy that
# provisions custom domains on Vercel. Leave unset in dev; the
# domain client short-circuits with `vercel-not-configured`.
# Token: Vercel dashboard → Settings → Tokens.
VERCEL_API_TOKEN=
# Project id: `vercel projects ls` or Vercel dashboard → project
# → Settings → General → Project ID.
VERCEL_PROJECT_ID=
# Team id (only if the project lives under a team, not a personal
# account). Vercel dashboard → team → Settings → General → Team ID.
VERCEL_TEAM_ID=
